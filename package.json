{
  "name": "@chang-store/vertex-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build:frontend": "npm --prefix frontend run build",
    "compile": "node ./scripts/check-node-platform.mjs --package-root . && tsc -p tsconfig.json && npm run build:frontend",
    "start": "node compiled/server.js",
    "test": "node ./scripts/check-node-platform.mjs --package-root . && vitest --run --config vitest.config.ts"
  },
  "dependencies": {
    "@google/genai": "^1.38.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "openai": "^6.41.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vitest": "^4.0.17"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "@rollup/rollup-linux-x64-gnu": "^4.62.2",
    "@rollup/rollup-linux-arm64-gnu": "^4.62.2",
    "@esbuild/win32-x64": "^0.28.0",
    "@esbuild/linux-x64": "^0.28.0",
    "@esbuild/linux-arm64": "^0.28.0"
  }
}
