PORT=8080
GATEWAY_API_KEYS=replace-this-with-a-local-dev-key
GATEWAY_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GOOGLE_APPLICATION_CREDENTIALS=/run/vertex-accounts/vertex-account-2.json
GOOGLE_VERTEX_PROJECT=project-b82b6a5a-13c8-42e4-a56
GOOGLE_VERTEX_LOCATION=global
# API key auth: set an API key to authenticate with Vertex AI without a
# service account JSON. When GOOGLE_VERTEX_PROJECT + GOOGLE_VERTEX_LOCATION are
# also set, the legacy single target uses full Vertex API-key mode by default.
# For explicit SDK API-key-only express behavior, use a pool target with
# "apiKeyMode": "express" in pool-config.local.json.
# GOOGLE_GENAI_API_KEY=your-google-cloud-api-key

# Quick multi-project setup (full Vertex API-key mode by default).
# Comma-separated entries in project:location:apiKey format. Because each entry
# includes project + location, the gateway uses the full Vertex resource path
# for these targets and auto-creates pool mode with round-robin.
# Overridden by pool-config.local.json if vertexPools is non-empty.
# VERTEX_POOLS=project-a:global:AIzaKey1,project-b:global:AIzaKey2,project-c:global:AIzaKey3

# Pool overlay file mounted by docker-compose. Defaults to the committed
# boot-safe example (single mode, empty vertexPools). Point this at your own
# gitignored overlay to enable pool mode, e.g. pool-config.local.json.
# GATEWAY_POOL_CONFIG=pool-config.local.json
